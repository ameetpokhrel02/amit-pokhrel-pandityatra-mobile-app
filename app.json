{
  "expo": {
    "name": "pandityatra-app",
    "slug": "pandityatra-app",
    "updates": {
      "enabled": false
    },
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/pandit-logo.png",
    "scheme": "pandityatraapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.pandityatraapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/pandit-logo.png",
        "backgroundColor": "#FFF7ED"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.anonymous.pandityatraapp"
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "asyncRoutes": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "PanditYatra needs camera access for video puja and document verification.",
          "microphonePermission": "PanditYatra needs microphone access for audio during video calls."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you set your profile picture."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/pandit-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFF7ED",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.anonymous.pandityatraapp",
          "enableGooglePay": false
        }
      ],
      "expo-video",
      "@react-native-community/datetimepicker",
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Allow PanditYatra to access your camera for sacred live video sessions.",
          "microphonePermission": "Allow PanditYatra to access your microphone for sacred live audio sessions."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow PanditYatra to access your location to find nearby pandits and calculate delivery charges.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "expoPublicGoogleClientId": "993632978293-r8vkjjvqctnhe5qujdje8c4d2hf7om1o.apps.googleusercontent.com",
      "androidClientId": "993632978293-r8vkjjvqctnhe5qujdje8c4d2hf7om1o.apps.googleusercontent.com",
      "webClientId": "993632978293-r8vkjjvqctnhe5qujdje8c4d2hf7om1o.apps.googleusercontent.com",
      "iosClientId": "993632978293-r8vkjjvqctnhe5qujdje8c4d2hf7om1o.apps.googleusercontent.com",
      "eas": {
        "projectId": "09230ecd-edac-4390-a27a-0afd616923c7"
      }
    }
  }
}
