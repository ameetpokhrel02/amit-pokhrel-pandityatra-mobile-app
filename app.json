{
  "expo": {
    "name": "pandityatra-app",
    "slug": "pandityatra-app",
    "updates": {
      "enabled": false
    },
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/pandit-logo.png",
    "scheme": "pandityatraapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.pandityatraapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/pandit-logo.png",
        "backgroundColor": "#FFF7ED"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.pandityatraapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you set your profile picture."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/pandit-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFF7ED",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.anonymous.pandityatraapp",
          "enableGooglePay": false
        }
      ],
      "expo-video",
      "@react-native-community/datetimepicker",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.741720641739-r771p005vit95lmbmnvjocdqggcfvk2f"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "expoPublicGoogleClientId": "993632978293-112fmct4s5ka6hctm8nk9hh8r7kuc9l1.apps.googleusercontent.com",
      "androidClientId": "741720641739-kat0ucp7uqnud1kfnuehrjhaid017hes.apps.googleusercontent.com",
      "webClientId": "993632978293-112fmct4s5ka6hctm8nk9hh8r7kuc9l1.apps.googleusercontent.com",
      "iosClientId": "741720641739-r771p005vit95lmbmnvjocdqggcfvk2f.apps.googleusercontent.com",
      "eas": {
        "projectId": "09230ecd-edac-4390-a27a-0afd616923c7"
      }
    }
  }
}
